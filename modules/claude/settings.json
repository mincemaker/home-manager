{
  "enabledPlugins": {
    "ruby-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "open-plan-mo",
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "guard-and-guide",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "rtk hook claude",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": "deepwiki-guard",
            "type": "command"
          }
        ],
        "matcher": "mcp__deepwiki__.*"
      }
    ]
  },
  "language": "Japanese",
  "permissions": {
    "allow": [
      "Bash(qs:*)",
      "WebSearch",
      "WebFetch(domain:docs.noctalia.dev)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:quickshell.outfoxxed.me)",
      "WebFetch(domain:quickshell.org)",
      "Bash(systemctl --user show-environment:*)",
      "WebFetch(domain:medium.com)"
    ],
    "deny": [
      "Bash(* .env*)",
      "Bash(* ~/.aws/*)",
      "Bash(* ~/.config/gh/*)",
      "Bash(* ~/.git-credentials)",
      "Bash(* ~/.netrc)",
      "Bash(* ~/.npmrc)",
      "Bash(* ~/.ssh/*)",
      "Bash(chmod 777:*)",
      "Bash(curl *)",
      "Bash(do)",
      "Bash(find * -delete*)",
      "Bash(for)",
      "Bash(gh repo delete:*)",
      "Bash(mongod:*)",
      "Bash(mysql:*)",
      "Bash(nc *)",
      "Bash(nc:*)",
      "Bash(ncat *)",
      "Bash(open *)",
      "Bash(osascript *)",
      "Bash(pbcopy *)",
      "Bash(pbpaste *)",
      "Bash(psql:*)",
      "Bash(push:*)",
      "Bash(pushf:*)",
      "Bash(rmdir *)",
      "Bash(rsync * --delete*)",
      "Bash(scp *)",
      "Bash(security *)",
      "Bash(shred *)",
      "Bash(ssh *)",
      "Bash(su *)",
      "Bash(sudo *)",
      "Bash(sudo:*)",
      "Bash(telnet *)",
      "Bash(unlink *)",
      "Bash(wget *)",
      "Bash(wget:*)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Edit(/secrets/**)",
      "Read(**/*.env*)",
      "Read(**/*key)",
      "Read(**/*secrets*)",
      "Read(**/*token*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(/secrets/**)",
      "Read(id_ed25519)",
      "Read(id_rsa)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.git-credentials)",
      "Read(~/.netrc)",
      "Read(~/.npmrc)",
      "Read(~/.ssh/**)",
      "Write(**/*.env*)",
      "Write(**/*key)",
      "Write(**/*secrets*)",
      "Write(**/*token*)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(/secrets/**)",
      "Write(id_ed25519)",
      "Write(id_rsa)",
      "mcp__supabase__execute_sql"
    ],
    "ask": [
      "Bash(curl:*)",
      "Bash(git config:*)",
      "Bash(git push:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git rm:*)",
      "Bash(git switch:*)"
    ],
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.ts"
  }
}
